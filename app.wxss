page {
  background: linear-gradient(180deg, #151023 0%, #0b1221 48%, #07111c 100%);
  color: #f4f7ff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 132rpx;
  box-sizing: border-box;
  max-width: 900rpx;
  margin: 0 auto;
}

.safe-bottom {
  padding-bottom: calc(136rpx + env(safe-area-inset-bottom));
}

.section {
  margin-top: 18rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #fff7fb;
}

.muted-text {
  color: #94a3b8;
}

.card,
.glass-card {
  background: rgba(255, 255, 255, 0.08);
  border: none;
  border-radius: 28rpx;
  box-shadow: none;
}

.glass-card {
  background: rgba(7, 11, 23, 0.78);
}

.card-padding {
  padding: 18rpx;
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.btn {
  border: none;
  border-radius: 24rpx;
  min-height: 72rpx;
  padding: 12rpx 18rpx;
  font-size: 25rpx;
  font-weight: 900;
  color: #f8fbff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #ffcf4a, #ff6b9d 52%, #7c5dff);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.12);
  color: #f4f7ff;
  border: none;
}

.btn-danger {
  background: linear-gradient(135deg, #ff4466, #ff6f8f);
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 800;
}

.badge-online {
  background: rgba(67, 246, 187, 0.16);
  color: #8cffcc;
}

.badge-offline {
  background: rgba(255, 68, 102, 0.12);
  color: #ff92b0;
}

.badge-xp {
  background: rgba(49, 215, 255, 0.16);
  color: #86e2ff;
}

.badge-battery {
  background: rgba(69, 140, 255, 0.16);
  color: #a6d7ff;
}

.badge-secondary {
  background: rgba(255, 255, 255, 0.09);
  color: #d9e3ff;
}

.progress-bar {
  width: 100%;
  height: 14rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(135deg, #31d7ff, #7c5dff);
  border-radius: 999rpx;
}

.grid-2 {
  display: flex;
  gap: 18rpx;
}

.grid-3 {
  display: flex;
  gap: 16rpx;
}

.compact-page {
  padding-top: 18rpx;
}

.compact-card {
  padding: 16rpx;
  border-radius: 28rpx;
}

.compact-section {
  margin-top: 16rpx;
}

.fit-screen {
  min-height: calc(100vh - 136rpx - env(safe-area-inset-bottom));
}

.mini-stat {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #cfe0ff;
  font-size: 21rpx;
}

.toy-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.app-screen {
  min-height: calc(100vh - 132rpx - env(safe-area-inset-bottom));
}

.hero-simple {
  padding: 18rpx 20rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.09);
}

.toy-launcher,
.compact-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.toy-tile {
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  box-shadow: inset 0 -1rpx 0 rgba(255, 255, 255, 0.08);
}

.big-play-button {
  width: 100%;
  min-height: 86rpx;
  border-radius: 30rpx;
  font-size: 30rpx;
}

.mini-action {
  flex: 1;
  min-height: 62rpx;
  border-radius: 22rpx;
  font-size: 22rpx;
}

.mini-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #f7fbff;
  font-size: 20rpx;
  font-weight: 800;
}

.simple-card {
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.1);
}

.language-chip {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #f4f7ff;
  font-size: 22rpx;
  font-weight: 800;
}

@media screen and (min-width: 720px) {
  .page-shell {
    padding-left: 32rpx;
    padding-right: 32rpx;
  }
}

.flex-center {
  display: flex;
  align-items: center;
}

.gap-large {
  gap: 28rpx;
}

.glow-soft {
  box-shadow: 0 0 0 1rpx rgba(49, 215, 255, 0.12), 0 18rpx 36rpx rgba(1, 9, 28, 0.24);
}
