page {
  background-color: #080b16;
  color: #f4f7ff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 22rpx 22rpx 136rpx;
  box-sizing: border-box;
  max-width: 920rpx;
  margin: 0 auto;
}

.safe-bottom {
  padding-bottom: calc(136rpx + env(safe-area-inset-bottom));
}

.section {
  margin-top: 18rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #e9f1ff;
}

.muted-text {
  color: #94a3b8;
}

.card,
.glass-card {
  background: rgba(15, 18, 30, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(22px);
  border-radius: 18rpx;
  box-shadow: 0 14rpx 36rpx rgba(2, 8, 22, 0.28);
}

.glass-card {
  background: rgba(7, 11, 23, 0.78);
}

.card-padding {
  padding: 18rpx;
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.btn {
  border: none;
  border-radius: 16rpx;
  min-height: 68rpx;
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #f8fbff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #31d7ff, #7c5dff);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.08);
  color: #cbd5e1;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.btn-danger {
  background: linear-gradient(135deg, #ff4466, #ff6f8f);
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 600;
}

.badge-online {
  background: rgba(67, 246, 187, 0.16);
  color: #8cffcc;
}

.badge-offline {
  background: rgba(255, 68, 102, 0.12);
  color: #ff92b0;
}

.badge-xp {
  background: rgba(49, 215, 255, 0.16);
  color: #86e2ff;
}

.badge-battery {
  background: rgba(69, 140, 255, 0.16);
  color: #a6d7ff;
}

.badge-secondary {
  background: rgba(255, 255, 255, 0.09);
  color: #d9e3ff;
}

.progress-bar {
  width: 100%;
  height: 14rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(135deg, #31d7ff, #7c5dff);
  border-radius: 999rpx;
}

.grid-2 {
  display: flex;
  gap: 18rpx;
}

.grid-3 {
  display: flex;
  gap: 16rpx;
}

.compact-page {
  padding-top: 18rpx;
}

.compact-card {
  padding: 16rpx;
  border-radius: 18rpx;
}

.compact-section {
  margin-top: 16rpx;
}

.fit-screen {
  min-height: calc(100vh - 136rpx - env(safe-area-inset-bottom));
}

.mini-stat {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #cfe0ff;
  font-size: 21rpx;
}

.toy-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

@media screen and (min-width: 720px) {
  .page-shell {
    padding-left: 32rpx;
    padding-right: 32rpx;
  }
}

.flex-center {
  display: flex;
  align-items: center;
}

.gap-large {
  gap: 28rpx;
}

.glow-soft {
  box-shadow: 0 0 0 1rpx rgba(49, 215, 255, 0.12), 0 18rpx 36rpx rgba(1, 9, 28, 0.24);
}
