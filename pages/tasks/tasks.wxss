.missions-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, rgba(255, 207, 74, 0.16), rgba(78, 205, 196, 0.12));
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.task-card {
  padding: 16rpx;
}

.task-card.done {
  opacity: 0.78;
}

.task-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.task-emoji {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.14);
  font-size: 34rpx;
  flex: none;
}

.task-main {
  flex: 1;
  min-width: 0;
}

.task-title {
  display: block;
  font-size: 25rpx;
  font-weight: 900;
  color: #fff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.task-meta {
  margin-top: 4rpx;
  color: #ffdf6a;
  font-size: 21rpx;
  font-weight: 900;
}

.done-chip {
  background: rgba(87, 236, 178, 0.2);
}

@media screen and (min-width: 720px) {
  .task-list {
    flex-direction: row;
    flex-wrap: wrap;
  }

  .task-card {
    flex: 1 1 40%;
  }
}
