.page-shell {
  min-height: 100vh;
}

.glass-card {
  background: rgba(7, 11, 23, 0.90);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
}

.card-padding {
  padding: 28rpx;
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.task-card {
  padding: 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.task-card.done {
  opacity: 0.72;
}

.task-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.task-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.progress-bar {
  width: 100%;
  height: 14rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(135deg, #31d7ff, #7c5dff);
  border-radius: 999rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.badge-online {
  background: rgba(67, 246, 187, 0.16);
  color: #8cffcc;
}

.badge-battery {
  background: rgba(69, 140, 255, 0.16);
  color: #a6d7ff;
}
