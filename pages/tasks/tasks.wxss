.missions-head {
  margin-bottom: 12rpx;
  background: linear-gradient(145deg, rgba(255, 230, 109, 0.1), rgba(78, 205, 196, 0.08));
}

.mission-copy {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.35;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.task-card {
  padding: 14rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.task-card.done {
  opacity: 0.72;
}

.task-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.task-emoji {
  width: 50rpx;
  height: 50rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  font-size: 28rpx;
  flex: none;
}

.task-main {
  flex: 1;
  min-width: 0;
}

.task-title {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #f4f7ff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.task-meta {
  display: flex;
  gap: 14rpx;
  margin-top: 4rpx;
  color: #94a3b8;
  font-size: 20rpx;
}

.mission-progress {
  height: 9rpx;
  margin-top: 10rpx;
}

@media screen and (min-width: 720px) {
  .task-list {
    flex-direction: row;
    flex-wrap: wrap;
  }

  .task-card {
    flex: 1 1 40%;
  }
}
