.page {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #8892b0;
  margin-bottom: 32rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #1a1a2e;
  border-radius: 16rpx;
  border: 1rpx solid #2d2d44;
}

.task-card.done {
  opacity: 0.6;
  border-color: #00ff8833;
}

.task-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #2d2d44;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  font-size: 24rpx;
  color: #00ff88;
}

.task-card.done .task-check {
  background: #00ff8822;
  border-color: #00ff88;
}

.task-info {
  flex: 1;
}

.task-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
}

.task-reward {
  display: block;
  font-size: 22rpx;
  color: #00d4ff;
  margin-top: 4rpx;
}
