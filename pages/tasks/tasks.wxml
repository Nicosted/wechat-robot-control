<view class="page-shell compact-page safe-bottom app-screen">
  <view class="hero-simple missions-head">
    <text class="section-title">{{sectionTitle}}</text>
    <text class="mini-chip">{{tasks.length}} {{missionsLabel}}</text>
  </view>

  <view class="task-list">
    <view
      wx:for="{{tasks}}"
      wx:key="id"
      class="simple-card task-card {{item.done ? 'done' : ''}}"
      data-id="{{item.id}}"
      bindtap="toggleTask"
    >
      <view class="task-row">
        <text class="task-emoji">{{item.emoji}}</text>
        <view class="task-main">
          <text class="task-title">{{item.title}}</text>
          <view class="task-meta">
            <text>{{item.stars}} {{starsLabel}}</text>
          </view>
        </view>
        <view class="mini-chip {{item.done ? 'done-chip' : ''}}">{{item.done ? completedLabel : pendingLabel}}</view>
      </view>
    </view>
  </view>

  <custom-tab-bar />
</view>
