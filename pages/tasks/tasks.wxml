<view class="page-shell safe-bottom">
  <view class="glass-card card-padding" style="margin-bottom: 24rpx;">
    <view class="card-row">
      <text class="section-title">{{sectionTitle}}</text>
      <view class="badge badge-xp">{{tasks.length}} {{missionsLabel}}</view>
    </view>
    <text class="muted-text" style="margin-top: 14rpx;">{{missionSubtitle}}</text>
  </view>

  <view class="task-list">
    <view
      wx:for="{{tasks}}"
      wx:key="id"
      class="glass-card task-card {{item.done ? 'done' : ''}}"
      data-id="{{item.id}}"
      bindtap="toggleTask"
    >
      <view class="task-row">
        <view>
          <text class="task-title">{{item.title}}</text>
          <view style="display: flex; gap: 10rpx; margin-top: 8rpx; align-items: center;">
            <text class="muted-text">{{earnLabel}} {{item.reward}} {{xpLabel}}</text>
            <text class="badge badge-xp" style="font-size: 20rpx; padding: 6rpx 12rpx;">{{item.stars}} {{starsLabel}}</text>
          </view>
        </view>
        <view class="badge {{item.done ? 'badge-online' : 'badge-battery'}}">{{item.done ? completedLabel : pendingLabel}}</view>
      </view>
      <view class="progress-bar" style="margin-top: 18rpx;">
        <view class="progress-fill" style="width: {{item.done ? '100%' : '34%'}}"></view>
      </view>
    </view>
  </view>

  <custom-tab-bar />
</view>
