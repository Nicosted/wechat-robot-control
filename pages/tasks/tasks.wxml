<view class="page-shell safe-bottom">
  <view class="glass-card card-padding" style="margin-bottom: 24rpx;">
    <view class="card-row">
      <text class="section-title">Mission Control</text>
      <view class="badge badge-xp">{{tasks.length}} Missions</view>
    </view>
    <text class="muted-text" style="margin-top: 14rpx;">Complete missions to earn XP and unlock advanced AI features.</text>
  </view>

  <view class="task-list">
    <view
      wx:for="{{tasks}}"
      wx:key="id"
      class="glass-card task-card {{item.done ? 'done' : ''}}"
      data-id="{{item.id}}"
      bindtap="toggleTask"
    >
      <view class="task-row">
        <view>
          <text class="task-title">{{item.title}}</text>
          <text class="muted-text">Earn {{item.reward}} XP</text>
        </view>
        <view class="badge {{item.done ? 'badge-online' : 'badge-battery'}}">{{item.done ? 'Completed' : 'Pending'}}</view>
      </view>
      <view class="progress-bar" style="margin-top: 18rpx;">
        <view class="progress-fill" style="width: {{item.done ? '100%' : '34%'}}"></view>
      </view>
    </view>
  </view>

  <custom-tab-bar />
</view>
