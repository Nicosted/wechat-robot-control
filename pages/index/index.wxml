<view class="page-shell compact-page safe-bottom fit-screen">
  <view class="card glass-card compact-card hero-card">
    <view class="card-row">
      <view>
        <text class="section-title hero-title">{{hub}}</text>
        <text class="muted-text hero-copy">{{hubSubtitle}}</text>
      </view>
      <view class="hero-chips">
        <view class="badge badge-xp">{{demoModeLabel}}</view>
        <view class="badge badge-online">{{safeModeLabel}}</view>
      </view>
    </view>
  </view>

  <view class="section compact-section">
    <text class="section-title section-tight">{{chooseBuddy}}</text>

    <view class="device-grid">
      <view
        wx:for="{{devices}}"
        wx:key="id"
        class="glass-card toy-card {{item.id === selectedDeviceId ? 'toy-card-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onDeviceTap"
      >
        <view class="toy-row">
          <text class="toy-emoji">{{item.emoji}}</text>
          <view class="toy-main">
            <view class="toy-topline">
              <text class="toy-name">{{item.name}}</text>
              <view class="toy-badge {{item.status === 'Online' ? 'badge-online' : 'badge-offline'}}">{{item.localizedStatus}}</view>
            </view>
            <text class="toy-type">{{item.localizedType}} · {{moodLabel}} {{item.localizedMood}}</text>
            <view class="toy-meter">
              <text class="mini-stat">{{energyLabel}}</text>
              <view class="progress-bar">
                <view class="progress-fill" style="width: {{item.energy}}%;"></view>
              </view>
              <text class="mini-stat">{{item.battery}}%</text>
            </view>
          </view>
          <button class="btn btn-primary toy-play">{{play}}</button>
        </view>
      </view>
    </view>
  </view>

  <view class="section compact-section">
    <text class="section-title section-tight">{{quickActions}}</text>
    <view class="action-grid home-actions">
      <button class="btn btn-primary" bindtap="goToControl">{{play}}</button>
      <button class="btn btn-secondary" bindtap="goToTasks">{{missionsLabel}}</button>
      <button class="btn btn-secondary" bindtap="goToAcademy">{{academyLabel}}</button>
      <button class="btn btn-secondary">{{safeModeLabel}}</button>
    </view>
  </view>

  <custom-tab-bar />
</view>
