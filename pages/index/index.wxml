<view class="page-shell safe-bottom">
  <view class="card glass-card card-padding hero-card">
    <view class="card-row">
      <view>
        <text class="section-title" style="font-size: 40rpx; margin-bottom: 12rpx;">{{hub}}</text>
        <text class="muted-text" style="line-height: 1.6;">{{hubSubtitle}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title" style="margin-bottom: 18rpx;">{{chooseBuddy}}</text>

    <view class="device-grid">
      <view
        wx:for="{{devices}}"
        wx:key="id"
        class="glass-card toy-card {{item.id === selectedDeviceId ? 'toy-card-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onDeviceTap"
      >
        <view class="toy-header">
          <text class="toy-emoji">{{item.emoji}}</text>
          <view class="toy-badge {{item.status === 'Online' ? 'badge-online' : 'badge-offline'}}">{{item.status}}</view>
        </view>
        <text class="toy-name">{{item.name}}</text>
        <text class="toy-type">{{item.type}}</text>
        <text class="toy-personality" style="margin-top: 10rpx; font-size: 22rpx;">{{item.personality}}</text>
        <view class="toy-mood-bar" style="margin-top: 12rpx;">
          <text class="mood-label">{{moodLabel}}: </text>
          <text class="mood-value">{{item.mood}}</text>
        </view>
        <view class="toy-energy-bar" style="margin-top: 8rpx;">
          <text class="energy-label">{{energyLabel}}: </text>
          <view class="progress-bar" style="flex: 1; margin-left: 8rpx;">
            <view class="progress-fill" style="width: {{item.energy}}%; background: linear-gradient(135deg, #31d7ff, #7c5dff);"></view>
          </view>
        </view>
        <view class="toy-play-mode" style="margin-top: 12rpx; font-size: 22rpx; color: #a6d7ff;">{{item.playMode}}</view>
        <view class="toy-stats" style="margin-top: 14rpx; display: flex; gap: 12rpx;">
          <view class="badge badge-xp">{{item.stars}} {{starsLabel}}</view>
          <view class="badge badge-battery">{{item.battery}}%</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">{{quickActions}}</text>
    <view class="grid-3" style="margin-top: 16rpx;">
      <button class="btn btn-primary" bindtap="goToControl">{{play}}</button>
      <button class="btn btn-secondary" bindtap="goToTasks">{{train}}</button>
      <button class="btn btn-secondary" bindtap="goToProfile">{{learn}}</button>
    </view>
  </view>

  <custom-tab-bar />
</view>
