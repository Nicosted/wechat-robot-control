<view class="page-shell compact-page safe-bottom app-screen">
  <view class="hero-simple hero-card">
    <view class="card-row">
      <view>
        <text class="section-title hero-title">{{hub}}</text>
        <text class="muted-text hero-copy">{{hubSubtitle}}</text>
      </view>
      <view class="hero-chips">
        <view class="mini-chip">{{demoModeLabel}}</view>
        <view class="mini-chip safe">{{safeModeLabel}}</view>
      </view>
    </view>
  </view>

  <view class="section launcher-section">
    <text class="section-title section-tight">{{chooseBuddy}}</text>

    <view class="toy-launcher">
      <view
        wx:for="{{devices}}"
        wx:key="id"
        class="toy-tile toy-card {{item.id === selectedDeviceId ? 'toy-card-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onDeviceTap"
      >
        <text class="toy-emoji">{{item.emoji}}</text>
        <text class="toy-name">{{item.name}}</text>
        <text class="toy-type">{{item.localizedType}}</text>
        <view class="tile-bottom">
          <text class="mini-chip">{{item.battery}}%</text>
          <text class="mini-chip">{{item.energy}}%</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section play-zone">
    <button class="btn btn-primary big-play-button" bindtap="goToControl">{{play}}</button>
    <view class="action-grid home-actions">
      <button class="btn btn-secondary mini-action" bindtap="goToTasks">{{missionsLabel}}</button>
      <button class="btn btn-secondary mini-action" bindtap="goToAcademy">{{academyLabel}}</button>
      <button class="btn btn-secondary mini-action">{{safeModeLabel}}</button>
    </view>
  </view>

  <custom-tab-bar />
</view>
