<view class="page-shell safe-bottom">
  <view class="card glass-card card-padding">
    <view class="card-row">
      <view>
        <text class="section-title">AI Toy Command</text>
        <text class="muted-text">Your premium command center for robots, drones, and AI pets.</text>
      </view>
      <view class="badge badge-xp">XP {{xp}}</view>
    </view>

    <view class="card-row" style="margin-top: 24rpx; gap: 12rpx; flex-wrap: wrap;">
      <view class="badge badge-online">Online: {{devices.length - 1}}</view>
      <view class="badge badge-battery">Battery: 62%</view>
      <view class="badge badge-offline">Standby: 1</view>
    </view>
  </view>

  <view class="section">
    <view class="card-row" style="margin-bottom: 18rpx;">
      <text class="section-title">Active Devices</text>
      <button class="btn btn-secondary" bindtap="goToControl">Manage</button>
    </view>

    <view class="device-grid">
      <view
        wx:for="{{devices}}"
        wx:key="id"
        class="glass-card device-card {{item.id === selectedDeviceId ? 'device-card-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onDeviceTap"
      >
        <view class="device-chip {{item.status === 'Online' ? 'badge-online' : 'badge-offline'}}">{{item.status}}</view>
        <view class="device-info">
          <text class="device-name">{{item.name}}</text>
          <text class="device-type">{{item.type}}</text>
          <text class="muted-text">{{item.description}}</text>
        </view>
        <view class="device-stats">
          <view class="badge badge-battery">{{item.battery}}%</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">Quick Actions</text>
    <view class="grid-3" style="margin-top: 16rpx;">
      <button class="btn btn-primary" bindtap="goToControl">Control</button>
      <button class="btn btn-secondary" bindtap="goToTasks">Tasks</button>
      <button class="btn btn-secondary" bindtap="goToProfile">Profile</button>
    </view>
  </view>

  <custom-tab-bar />
</view>
