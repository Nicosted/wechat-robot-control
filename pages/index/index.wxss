.device-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
}

.device-card {
  padding: 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  overflow: hidden;
  min-height: 212rpx;
}

.device-card-active {
  border-color: rgba(67, 246, 187, 0.4);
  box-shadow: 0 0 0 1rpx rgba(67, 246, 187, 0.18);
}

.device-chip {
  margin-bottom: 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.device-info {
  margin-bottom: 18rpx;
}

.device-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.device-type {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 6rpx;
}

.device-stats {
  display: flex;
  justify-content: flex-end;
}

@media screen and (min-width: 720px) {
  .device-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
