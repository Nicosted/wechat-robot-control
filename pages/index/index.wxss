.hero-card {
  background: linear-gradient(160deg, rgba(49, 215, 255, 0.1), rgba(255, 107, 157, 0.08));
  border: 1rpx solid rgba(78, 205, 196, 0.16);
  margin-bottom: 24rpx;
}

.device-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
}

.toy-card {
  padding: 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  overflow: hidden;
  min-height: auto;
  transition: all 160ms ease;
  cursor: pointer;
}

.toy-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 24rpx 48rpx rgba(0, 0, 0, 0.3);
}

.toy-card-active {
  border-color: rgba(78, 205, 196, 0.4);
  box-shadow: 0 0 0 2rpx rgba(78, 205, 196, 0.2), 0 18rpx 36rpx rgba(0, 0, 0, 0.24);
}

.toy-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.toy-emoji {
  font-size: 48rpx;
  display: block;
}

.toy-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.toy-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #f4f7ff;
  margin-bottom: 4rpx;
}

.toy-type {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 6rpx;
}

.toy-personality {
  display: block;
  color: #a6d7ff;
  font-weight: 600;
}

.mood-label {
  color: #94a3b8;
  font-size: 20rpx;
}

.mood-value {
  color: #f4f7ff;
  font-weight: 600;
}

.energy-label {
  color: #94a3b8;
  font-size: 20rpx;
}

.toy-play-mode {
  display: block;
  font-style: italic;
}

.toy-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.device-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
}

.device-card {
  padding: 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  overflow: hidden;
  min-height: 212rpx;
}

.device-card-active {
  border-color: rgba(67, 246, 187, 0.4);
  box-shadow: 0 0 0 1rpx rgba(67, 246, 187, 0.18);
}

.device-chip {
  margin-bottom: 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.device-info {
  margin-bottom: 18rpx;
}

.device-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.device-type {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 6rpx;
}

.device-stats {
  display: flex;
  justify-content: flex-end;
}

@media screen and (min-width: 720px) {
  .device-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
