.hero-card {
  background: linear-gradient(145deg, rgba(49, 215, 255, 0.12), rgba(255, 107, 157, 0.08));
  border-color: rgba(78, 205, 196, 0.16);
}

.hero-title {
  font-size: 34rpx;
  margin-bottom: 6rpx;
}

.hero-copy {
  display: block;
  line-height: 1.35;
  font-size: 23rpx;
}

.hero-chips {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex: none;
}

.section-tight {
  margin-bottom: 12rpx;
}

.device-grid {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.toy-card {
  padding: 14rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.toy-card-active {
  border-color: rgba(78, 205, 196, 0.42);
  box-shadow: 0 0 0 2rpx rgba(78, 205, 196, 0.16);
}

.toy-emoji {
  width: 62rpx;
  height: 62rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  flex: none;
}

.toy-main {
  flex: 1;
  min-width: 0;
}

.toy-topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10rpx;
}

.toy-name {
  font-size: 26rpx;
  font-weight: 800;
  color: #f4f7ff;
}

.toy-type {
  display: block;
  margin-top: 2rpx;
  color: #94a3b8;
  font-size: 21rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.toy-badge {
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 800;
}

.toy-meter {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.toy-meter .progress-bar {
  flex: 1;
  height: 10rpx;
}

.toy-play {
  width: 96rpx;
  min-height: 56rpx;
  font-size: 22rpx;
  padding: 8rpx 10rpx;
  flex: none;
}

.home-actions .btn {
  flex: 1 1 45%;
}

@media screen and (min-width: 720px) {
  .device-grid {
    flex-direction: row;
    flex-wrap: wrap;
  }

  .toy-card {
    flex: 1 1 40%;
  }
}
