.hero-card {
  background: linear-gradient(135deg, rgba(255, 207, 74, 0.16), rgba(255, 107, 157, 0.12));
}

.hero-title {
  font-size: 34rpx;
  margin-bottom: 4rpx;
}

.hero-copy {
  display: block;
  line-height: 1.28;
  font-size: 23rpx;
}

.hero-chips {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex: none;
}

.hero-chips .safe {
  background: rgba(87, 236, 178, 0.18);
}

.launcher-section {
  margin-top: 18rpx;
}

.section-tight {
  margin-bottom: 12rpx;
}

.toy-card {
  flex: 1 1 30%;
  min-width: 190rpx;
  min-height: 194rpx;
  padding: 18rpx 12rpx;
  text-align: center;
  box-sizing: border-box;
}

.toy-card-active {
  background: linear-gradient(160deg, rgba(255, 207, 74, 0.22), rgba(255, 107, 157, 0.18));
  box-shadow: 0 0 0 3rpx rgba(255, 207, 74, 0.32);
}

.toy-emoji {
  display: block;
  font-size: 58rpx;
  line-height: 1;
}

.toy-name {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  font-weight: 900;
  color: #fff;
}

.toy-type {
  display: block;
  margin-top: 2rpx;
  color: #c8d4ef;
  font-size: 20rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tile-bottom {
  display: flex;
  justify-content: center;
  gap: 6rpx;
  margin-top: 12rpx;
}

.play-zone {
  margin-top: 16rpx;
}

.home-actions {
  margin-top: 10rpx;
}

@media screen and (min-width: 720px) {
  .toy-card {
    min-height: 220rpx;
  }
}
