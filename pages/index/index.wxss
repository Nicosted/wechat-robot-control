.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 48rpx;
}

.greeting-label {
  display: block;
  font-size: 28rpx;
  color: #8892b0;
}

.greeting-name {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  margin-top: 8rpx;
  background: linear-gradient(90deg, #00d4ff, #7b2ff7);
  -webkit-background-clip: text;
  color: transparent;
}

.xp-card {
  margin-top: 32rpx;
  padding: 24rpx;
  background: #1a1a2e;
  border-radius: 16rpx;
  border: 1rpx solid #2d2d44;
}

.xp-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.xp-label {
  font-size: 24rpx;
  color: #8892b0;
}

.xp-value {
  font-size: 24rpx;
  color: #00d4ff;
}

.xp-bar {
  height: 12rpx;
  background: #0f0f1e;
  border-radius: 6rpx;
  overflow: hidden;
}

.xp-fill {
  height: 100%;
  background: linear-gradient(90deg, #00d4ff, #7b2ff7);
  border-radius: 6rpx;
}

.section {
  margin-bottom: 48rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #ccd6f6;
}

.robot-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.robot-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #1a1a2e;
  border-radius: 16rpx;
  border: 1rpx solid #2d2d44;
}

.robot-card.online {
  border-color: #00d4ff33;
}

.robot-card.offline {
  opacity: 0.7;
}

.robot-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.robot-info {
  flex: 1;
}

.robot-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.robot-type {
  display: block;
  font-size: 22rpx;
  color: #8892b0;
  text-transform: capitalize;
  margin-top: 4rpx;
}

.robot-status {
  text-align: right;
}

.status-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.dot-online {
  background: #00ff88;
  box-shadow: 0 0 8rpx #00ff88;
}

.dot-offline {
  background: #ff4466;
}

.status-text {
  font-size: 22rpx;
  color: #8892b0;
}

.battery {
  display: block;
  font-size: 22rpx;
  color: #00d4ff;
  margin-top: 8rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  font-size: 26rpx;
  background: #1a1a2e;
  color: #ccd6f6;
  border: 1rpx solid #2d2d44;
  border-radius: 12rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #00d4ff, #7b2ff7);
  color: #fff;
  border: none;
}
