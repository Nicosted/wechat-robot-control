<view class="page-shell compact-page safe-bottom app-screen">
  <view class="hero-simple academy-hero">
    <view class="card-row">
      <view>
        <text class="section-title">{{academyTitle}}</text>
        <text class="muted-text academy-copy">{{academySubtitle}}</text>
      </view>
    </view>
  </view>

  <view class="section academy-menu">
    <view class="academy-grid">
      <view wx:for="{{lessons}}" wx:key="id" class="simple-card academy-card">
        <view class="academy-card-top">
          <text class="lesson-emoji">{{item.emoji}}</text>
          <text class="star-score">{{item.stars}}</text>
        </view>
        <text class="lesson-name">{{item.title}}</text>
        <view class="progress-summary">
          <text class="progress-text">{{item.progress}}%</text>
        </view>
      </view>
    </view>
    <button class="btn btn-primary big-play-button academy-cta" bindtap="startLearning">{{startLearningBtn}}</button>
  </view>

  <custom-tab-bar />
</view>
