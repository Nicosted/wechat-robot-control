.academy-hero {
  background: linear-gradient(150deg, rgba(78, 205, 196, 0.14), rgba(255, 107, 157, 0.1));
}

.academy-copy {
  display: block;
  margin-top: 6rpx;
  line-height: 1.35;
  font-size: 22rpx;
}

.section-subtitle {
  display: block;
  color: #94a3b8;
  font-size: 21rpx;
  margin-bottom: 4rpx;
}

.lesson-title {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #f4f7ff;
}

.today-card {
  margin-top: 12rpx;
}

.path-head {
  margin-bottom: 12rpx;
}

.path-head .btn {
  min-height: 56rpx;
  font-size: 21rpx;
  padding: 8rpx 12rpx;
}

.academy-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.academy-card {
  flex: 1 1 42%;
  min-width: 240rpx;
}

.academy-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.lesson-emoji {
  font-size: 30rpx;
}

.lesson-name {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  font-weight: 800;
  color: #fff;
}

.lesson-note {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.star-score {
  font-size: 20rpx;
  color: #ffe66d;
}

.progress-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
}

.progress-text,
.practice-text {
  color: #d9e3ff;
  font-size: 20rpx;
  font-weight: 700;
}

.academy-progress {
  height: 9rpx;
  margin-top: 6rpx;
  background: rgba(255, 255, 255, 0.05);
}

.badge-academy {
  flex: none;
  background: rgba(255, 255, 255, 0.08);
  color: #f4f7ff;
}

@media screen and (min-width: 720px) {
  .academy-card {
    flex-basis: 22%;
  }
}
