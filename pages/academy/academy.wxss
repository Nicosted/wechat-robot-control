.academy-hero {
  background: linear-gradient(135deg, rgba(124, 93, 255, 0.16), rgba(78, 205, 196, 0.13));
}

.academy-copy {
  display: block;
  margin-top: 4rpx;
  line-height: 1.28;
  font-size: 23rpx;
}

.academy-menu {
  margin-top: 16rpx;
}

.academy-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.academy-card {
  flex: 1 1 42%;
  min-width: 230rpx;
  min-height: 170rpx;
  padding: 18rpx;
  box-sizing: border-box;
}

.academy-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.lesson-emoji {
  font-size: 42rpx;
}

.lesson-name {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
  font-weight: 900;
  color: #fff;
}

.star-score {
  font-size: 20rpx;
  color: #ffdf6a;
}

.progress-summary {
  margin-top: 10rpx;
}

.progress-text {
  color: #cfe0ff;
  font-size: 22rpx;
  font-weight: 900;
}

.academy-cta {
  margin-top: 14rpx;
}

@media screen and (min-width: 720px) {
  .academy-card {
    flex-basis: 22%;
  }
}
