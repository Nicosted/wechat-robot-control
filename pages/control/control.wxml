<view class="page-shell safe-bottom">
  <view class="glass-card card-padding">
    <view class="card-row" style="margin-bottom: 16rpx;">
      <view>
        <text class="section-title">{{robotName}}</text>
        <text class="muted-text">{{description}}</text>
      </view>
      <view class="badge {{connected ? 'badge-online' : 'badge-offline'}}">{{connected ? connectedLabel : standbyLabel}}</view>
    </view>

    <view class="card-row" style="gap: 12rpx; flex-wrap: wrap; margin-top: 14rpx;">
      <view class="badge badge-battery">{{batteryLabel}} {{battery}}%</view>
      <view class="badge badge-xp">{{modeLabel}} {{mode}}</view>
      <view class="badge badge-secondary">{{accentLabel}}</view>
    </view>
  </view>

  <view class="section">
    <view class="glass-card card-padding control-panel">
      <view class="panel-heading" style="margin-bottom: 18rpx;">
        <text class="section-subtitle">{{controlPadLabel}}</text>
        <text class="muted-text">{{precisionMovementLabel}}</text>
      </view>

      <view class="joystick-pad">
        <view class="joy-row justify-center">
          <button class="joy-btn direction joy-up" disabled="{{!connected}}" data-action="Up" bindtap="handleAction">▲</button>
        </view>

        <view class="joy-row joy-mid-row">
          <button class="joy-btn direction joy-left" disabled="{{!connected}}" data-action="Left" bindtap="handleAction">◀</button>
          <button class="joy-btn stop" disabled="{{!connected}}" data-action="STOP" bindtap="handleAction">STOP</button>
          <button class="joy-btn direction joy-right" disabled="{{!connected}}" data-action="Right" bindtap="handleAction">▶</button>
        </view>

        <view class="joy-row justify-center">
          <button class="joy-btn direction joy-down" disabled="{{!connected}}" data-action="Down" bindtap="handleAction">▼</button>
        </view>
      </view>

      <view class="control-actions">
        <button class="btn btn-secondary action-btn" data-action="Auto" bindtap="handleAction">{{autoPlayLabel}}</button>
        <button class="btn btn-secondary action-btn" data-action="Voice" bindtap="handleAction">{{talkLabel}}</button>
        <button class="btn btn-secondary action-btn" data-action="Lights" bindtap="handleAction">{{glowLabel}}</button>
        <button class="btn btn-secondary action-btn" data-action="Return" bindtap="handleAction">{{comeBackLabel}}</button>
        <button wx:if="{{!connected}}" class="btn btn-primary action-btn" bindtap="connect">{{connectLabel}}</button>
        <button wx:else class="btn btn-danger action-btn" bindtap="disconnect">{{disconnectLabel}}</button>
      </view>
    </view>
  </view>

  <custom-tab-bar />
</view>
