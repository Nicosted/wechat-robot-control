<view class="page-shell safe-bottom">
  <view class="glass-card card-padding">
    <view class="card-row" style="margin-bottom: 16rpx;">
      <view>
        <text class="section-title">{{robotName}}</text>
        <text class="muted-text">{{description}}</text>
      </view>
      <view class="badge {{connected ? 'badge-online' : 'badge-offline'}}">{{connected ? 'Connected' : 'Standby'}}</view>
    </view>

    <view class="card-row" style="gap: 12rpx; flex-wrap: wrap; margin-top: 14rpx;">
      <view class="badge badge-battery">Battery {{battery}}%</view>
      <view class="badge badge-xp">Mode {{mode}}</view>
      <view class="badge badge-secondary">{{accentLabel}}</view>
    </view>
  </view>

  <view class="section">
    <view class="glass-card card-padding">
      <view class="joystick-grid">
        <view class="control-cell"></view>
        <button class="ctrl-btn direction" disabled="{{!connected}}" data-action="Up" bindtap="handleAction">▲</button>
        <view class="control-cell"></view>

        <button class="ctrl-btn direction" disabled="{{!connected}}" data-action="Left" bindtap="handleAction">◀</button>
        <button class="ctrl-btn stop" disabled="{{!connected}}" data-action="STOP" bindtap="handleAction">STOP</button>
        <button class="ctrl-btn direction" disabled="{{!connected}}" data-action="Right" bindtap="handleAction">▶</button>

        <view class="control-cell"></view>
        <button class="ctrl-btn direction" disabled="{{!connected}}" data-action="Down" bindtap="handleAction">▼</button>
        <view class="control-cell"></view>
      </view>

      <view class="grid-3" style="margin-top: 20rpx;">
        <button class="btn btn-secondary" data-action="Auto" bindtap="handleAction">Auto</button>
        <button class="btn btn-secondary" data-action="Voice" bindtap="handleAction">Voice</button>
        <button class="btn btn-secondary" data-action="Lights" bindtap="handleAction">Lights</button>
      </view>

      <view class="grid-3" style="margin-top: 14rpx;">
        <button class="btn btn-secondary" data-action="Return" bindtap="handleAction">Return</button>
        <button wx:if="{{!connected}}" class="btn btn-primary" bindtap="connect">Connect</button>
        <button wx:else class="btn btn-danger" bindtap="disconnect">Disconnect</button>
      </view>
    </view>
  </view>

  <custom-tab-bar />
</view>
