.control-panel {
  background: linear-gradient(180deg, rgba(9, 13, 29, 0.96), rgba(14, 20, 40, 0.95));
  border: 1rpx solid rgba(80, 170, 255, 0.12);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.04), 0 30rpx 70rpx rgba(0, 0, 0, 0.28);
}

.panel-heading {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-subtitle {
  display: block;
  color: #b0c6ff;
  font-size: 24rpx;
  font-weight: 700;
}

.joystick-pad {
  width: 100%;
  max-width: 540rpx;
  margin: 0 auto;
  padding: 24rpx 0 12rpx;
}

.joy-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.joy-mid-row {
  justify-content: space-between;
  gap: 18rpx;
}

.joy-btn {
  width: 118rpx;
  height: 118rpx;
  border: none;
  border-radius: 28rpx;
  color: #f4f7ff;
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  cursor: pointer;
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
}

.joy-btn.direction {
  background: linear-gradient(145deg, #12254b, #0a1427);
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.35), inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(116, 177, 255, 0.12);
}

.joy-btn.direction::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 28rpx;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.04);
}

.joy-btn.stop {
  width: 154rpx;
  height: 154rpx;
  border-radius: 50%;
  font-size: 26rpx;
  letter-spacing: 1px;
  background: radial-gradient(circle at 30% 30%, #ff6f8f, #ff274f 65%);
  box-shadow: 0 28rpx 58rpx rgba(255, 46, 85, 0.22), inset 0 1rpx 0 rgba(255, 255, 255, 0.18);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  z-index: 2;
}

.joy-btn.stop::before {
  content: '';
  position: absolute;
  inset: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.joy-btn.direction:active,
.joy-btn.stop:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 14rpx 28rpx rgba(0, 0, 0, 0.3);
}

.joy-btn.direction:disabled,
.joy-btn.stop:disabled {
  opacity: 0.48;
}

.control-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
  justify-content: center;
}

.action-btn {
  flex: 1 1 45%;
  min-width: 140rpx;
  max-width: 188rpx;
  padding: 18rpx 0;
  border-radius: 18rpx;
}

.action-btn:nth-child(1),
.action-btn:nth-child(4) {
  flex: 1 1 48%;
}

.action-btn:nth-child(5),
.action-btn:nth-child(6) {
  flex: 1 1 100%;
}

@media screen and (max-width: 560px) {
  .joy-btn.direction {
    width: 104rpx;
    height: 104rpx;
    border-radius: 24rpx;
  }

  .joy-btn.stop {
    width: 136rpx;
    height: 136rpx;
  }

  .control-actions {
    gap: 10rpx;
  }
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.02);
  }
}
