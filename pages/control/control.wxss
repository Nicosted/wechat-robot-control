.control-summary {
  background: linear-gradient(145deg, rgba(78, 205, 196, 0.1), rgba(124, 93, 255, 0.08));
}

.control-emoji {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  font-size: 34rpx;
  flex: none;
}

.summary-main {
  flex: 1;
  min-width: 0;
}

.summary-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.summary-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 14rpx;
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 21rpx;
}

.control-panel {
  background: linear-gradient(180deg, rgba(9, 13, 29, 0.96), rgba(14, 20, 40, 0.95));
  border: 1rpx solid rgba(80, 170, 255, 0.12);
}

.panel-heading {
  display: flex;
  justify-content: center;
}

.section-subtitle {
  display: block;
  color: #b0c6ff;
  font-size: 24rpx;
  font-weight: 800;
}

.joystick-pad {
  width: 100%;
  max-width: 460rpx;
  margin: 8rpx auto 0;
}

.joy-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.joy-mid-row {
  gap: 14rpx;
}

.joy-btn {
  width: 94rpx;
  height: 94rpx;
  border: none;
  border-radius: 24rpx;
  color: #f4f7ff;
  font-size: 28rpx;
  font-weight: 800;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.joy-btn.direction {
  background: linear-gradient(145deg, #12254b, #0a1427);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(116, 177, 255, 0.12);
}

.joy-btn.stop {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  font-size: 22rpx;
  background: radial-gradient(circle at 30% 30%, #ff6f8f, #ff274f 65%);
  color: #fff;
}

.joy-btn.direction:disabled,
.joy-btn.stop:disabled {
  opacity: 0.48;
}

.control-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.action-btn {
  flex: 1 1 30%;
  min-width: 152rpx;
  min-height: 60rpx;
  padding: 10rpx 8rpx;
  font-size: 22rpx;
}

@media screen and (min-width: 720px) {
  .control-panel {
    max-width: 620rpx;
    margin: 0 auto;
  }
}
