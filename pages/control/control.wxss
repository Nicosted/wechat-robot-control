.joystick-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  grid-template-rows: repeat(3, auto);
  gap: 14rpx;
  justify-items: center;
  align-items: center;
}

.control-cell {
  width: 108rpx;
  height: 108rpx;
}

.ctrl-btn {
  width: 108rpx;
  height: 108rpx;
  border: none;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fbff;
  background: linear-gradient(135deg, #1f3053, #111827);
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.24);
  padding: 0;
  line-height: 108rpx;
}

.ctrl-btn:disabled {
  opacity: 0.5;
}

.ctrl-btn.stop {
  width: 146rpx;
  height: 146rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff526b, #ff2d55);
  box-shadow: 0 0 0 10rpx rgba(255, 45, 85, 0.18);
  animation: pulse 1.8s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.04);
  }
}
