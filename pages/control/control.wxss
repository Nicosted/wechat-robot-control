.page {
  padding: 32rpx 32rpx 140rpx;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  background: linear-gradient(180deg, #0f172a 0%, #111827 100%);
}

.status-card {
  width: 100%;
  max-width: 640rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #1a1a2e, #20243d);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.25);
  text-align: center;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
  color: #dce7ff;
  background: rgba(255, 255, 255, 0.08);
}

.status-badge.online {
  color: #7cffb2;
}

.status-badge.offline {
  color: #ff7a90;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff7a90;
}

.status-badge.online .status-dot {
  background: #7cffb2;
  box-shadow: 0 0 10rpx #7cffb2;
}

.robot-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  color: #f8fbff;
}

.robot-subtitle {
  display: block;
  font-size: 24rpx;
  color: #88a0c5;
}

.controls-panel {
  width: 100%;
  max-width: 640rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 26rpx 0 10rpx;
}

.joystick-grid {
  display: grid;
  grid-template-columns: repeat(3, 140rpx);
  grid-template-rows: repeat(3, 140rpx);
  gap: 20rpx;
  align-items: center;
  justify-items: center;
}

.control-cell {
  width: 140rpx;
  height: 140rpx;
}

.control-btn {
  width: 140rpx;
  height: 140rpx;
  border: none;
  border-radius: 30rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #f7fbff;
  background: linear-gradient(135deg, #243b53, #141e30);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.28);
  padding: 0;
  line-height: 140rpx;
}

.control-btn::after {
  border: none;
}

.control-btn:disabled {
  opacity: 0.6;
}

.control-btn.stop {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff5b6c, #ff2d55);
  color: #fff;
  box-shadow: 0 0 0 10rpx rgba(255, 45, 85, 0.18);
  animation: pulse 1.8s infinite;
}

.control-btn.direction.forward {
  background: linear-gradient(135deg, #2d8cff, #1f5bd8);
}

.control-btn.direction.left {
  background: linear-gradient(135deg, #2d8cff, #1f5bd8);
}

.control-btn.direction.right {
  background: linear-gradient(135deg, #2d8cff, #1f5bd8);
}

.control-btn.direction.back {
  background: linear-gradient(135deg, #2d8cff, #1f5bd8);
}

.actions {
  width: 100%;
  max-width: 640rpx;
  margin-top: 8rpx;
}

.action-btn {
  width: 100%;
  border-radius: 18rpx;
  font-size: 30rpx;
  padding: 18rpx 0;
  border: none;
}

.action-btn.connect {
  background: linear-gradient(135deg, #00d4ff, #7b2ff7);
  color: #fff;
}

.action-btn.disconnect {
  background: rgba(255, 255, 255, 0.08);
  color: #ff7a90;
  border: 1rpx solid rgba(255, 122, 144, 0.35);
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.04);
  }
}
