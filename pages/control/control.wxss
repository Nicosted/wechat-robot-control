.control-summary {
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(255, 207, 74, 0.16), rgba(78, 205, 196, 0.13));
}

.control-toy {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.control-emoji {
  width: 104rpx;
  height: 104rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.16);
  font-size: 58rpx;
  flex: none;
}

.summary-main {
  flex: 1;
  min-width: 0;
}

.summary-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.summary-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
  color: #eef6ff;
  font-size: 22rpx;
  font-weight: 800;
}

.summary-stats text {
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
}

.is-online {
  background: rgba(87, 236, 178, 0.2);
}

.is-offline {
  background: rgba(255, 107, 157, 0.2);
}

.play-controller {
  margin-top: 18rpx;
}

.control-panel {
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.08);
}

.joystick-pad {
  width: 100%;
  max-width: 440rpx;
  margin: 0 auto;
}

.joy-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.joy-mid-row {
  gap: 16rpx;
}

.joy-btn {
  width: 98rpx;
  height: 98rpx;
  border: none;
  border-radius: 30rpx;
  color: #f4f7ff;
  font-size: 30rpx;
  font-weight: 900;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.joy-btn.direction {
  background: rgba(255, 255, 255, 0.13);
}

.joy-btn.stop {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  font-size: 22rpx;
  background: linear-gradient(135deg, #ff365d, #ff8a4a);
  color: #fff;
  box-shadow: 0 14rpx 34rpx rgba(255, 70, 105, 0.24);
}

.joy-btn.direction:disabled,
.joy-btn.stop:disabled {
  opacity: 0.5;
}

.control-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.action-btn {
  flex: 1 1 30%;
  min-width: 150rpx;
  min-height: 66rpx;
  padding: 10rpx 8rpx;
  font-size: 22rpx;
}

@media screen and (min-width: 720px) {
  .control-panel {
    max-width: 620rpx;
    margin: 0 auto;
  }
}
