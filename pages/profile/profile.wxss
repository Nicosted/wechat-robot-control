.profile-card {
  margin-bottom: 12rpx;
  background: linear-gradient(145deg, rgba(49, 215, 255, 0.12), rgba(255, 230, 109, 0.08));
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #31d7ff, #7c5dff);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #fff;
  flex: none;
}

.stats-grid {
  display: flex;
  gap: 10rpx;
}

.stat-card {
  flex: 1;
  padding: 14rpx 8rpx;
  border-radius: 16rpx;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #31d7ff;
}

.stat-label {
  display: block;
  font-size: 19rpx;
  color: #94a3b8;
  margin-top: 2rpx;
  white-space: nowrap;
}

.profile-section {
  margin-top: 12rpx;
}

.mini-heading {
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.device-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.device-row,
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 9rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  gap: 12rpx;
  font-size: 22rpx;
}

.device-row:last-child,
.setting-row:last-child {
  border-bottom: none;
}

.device-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.device-emoji {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex: none;
}

.device-name,
.device-mood {
  display: block;
}

.device-name {
  font-size: 23rpx;
  font-weight: 800;
}

.device-mood {
  font-size: 20rpx;
}

.language-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: 6rpx 0 8rpx;
}

.lang-pill {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.07);
  color: #dce8ff;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  font-size: 21rpx;
  font-weight: 700;
}

.lang-pill.active {
  background: rgba(49, 215, 255, 0.18);
  color: #8de8ff;
  border-color: rgba(49, 215, 255, 0.28);
}
