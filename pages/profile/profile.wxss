.profile-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #31d7ff, #7c5dff);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.stats-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stat-card {
  width: 100%;
  padding: 24rpx;
  background: rgba(7, 11, 23, 0.92);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #31d7ff;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 10rpx;
}

.device-list,
.setting-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.device-row,
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  gap: 16rpx;
}

.device-row text,
.setting-row text {
  flex: 1;
}

.device-row:last-child,
.setting-row:last-child {
  border-bottom: none;
}

.device-row text,
.setting-row text {
  font-size: 24rpx;
}
