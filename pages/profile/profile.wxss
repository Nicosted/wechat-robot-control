.profile-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #31d7ff, #7c5dff);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-card {
  width: 100%;
  padding: 24rpx;
  background: rgba(7, 11, 23, 0.92);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  text-align: center;
}

.profile-favorite {
  margin-top: 24rpx;
  background: linear-gradient(135deg, rgba(255, 230, 109, 0.14), rgba(255, 107, 157, 0.12));
}

.favorite-name {
  display: block;
  margin-top: 8rpx;
  color: #ffe66d;
  font-size: 34rpx;
  font-weight: 800;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #31d7ff;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 10rpx;
}

.device-list,
.setting-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.device-row,
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  gap: 16rpx;
}

.device-row text,
.setting-row text {
  flex: 1;
}

.device-main {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
}

.device-emoji {
  width: 52rpx;
  height: 52rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex: none;
}

.device-name,
.device-mood {
  display: block;
}

.device-row:last-child,
.setting-row:last-child {
  border-bottom: none;
}

.device-row text,
.setting-row text {
  font-size: 24rpx;
}

.language-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 6rpx 0 18rpx;
}

.lang-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.07);
  color: #dce8ff;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  font-size: 22rpx;
  font-weight: 600;
}

.lang-pill.active {
  background: rgba(49, 215, 255, 0.18);
  color: #8de8ff;
  border-color: rgba(49, 215, 255, 0.28);
}
