.profile-card {
  background: linear-gradient(135deg, rgba(255, 207, 74, 0.16), rgba(255, 107, 157, 0.13));
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  color: #fff;
  flex: none;
}

.stats-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.stat-card {
  flex: 1;
  padding: 16rpx 8rpx;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
  color: #ffdf6a;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #d8e4fb;
  margin-top: 2rpx;
  white-space: nowrap;
}

.profile-section {
  margin-top: 14rpx;
  padding: 16rpx;
}

.mini-heading {
  font-size: 25rpx;
  margin-bottom: 8rpx;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 9rpx 0;
  gap: 12rpx;
  font-size: 23rpx;
  font-weight: 800;
}

.language-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.lang-pill.active {
  background: linear-gradient(135deg, #ffcf4a, #ff6b9d);
  color: #fff;
}

.settings-panel {
  padding-top: 10rpx;
  padding-bottom: 10rpx;
}
