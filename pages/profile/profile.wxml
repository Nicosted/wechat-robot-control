<view class="page-shell safe-bottom">
  <view class="glass-card card-padding" style="margin-bottom: 24rpx;">
    <view class="card-row">
      <view class="profile-header">
        <view class="avatar">{{avatarEmoji}}</view>
        <view>
          <text class="section-title">{{userInfo.nickName}}</text>
          <text class="muted-text">{{toyTrainerLabel}}</text>
        </view>
      </view>
      <view class="badge badge-xp">{{levelLabel}}</view>
    </view>

    <view style="margin-top: 22rpx;">
      <text class="muted-text">{{starsEarnedLabel}}</text>
      <view class="progress-bar" style="margin-top: 12rpx;">
        <view class="progress-fill" style="width: 62%;"></view>
      </view>
    </view>
  </view>

  <view class="stats-grid">
    <view class="glass-card stat-card">
      <text class="stat-value">{{stats.robotsOwned}}</text>
      <text class="stat-label">{{toysUnlockedLabel}}</text>
    </view>
    <view class="glass-card stat-card">
      <text class="stat-value">{{stats.tasksCompleted}}</text>
      <text class="stat-label">{{missionsDoneLabel}}</text>
    </view>
    <view class="glass-card stat-card">
      <text class="stat-value">{{stats.stars}}</text>
      <text class="stat-label">{{starsEarnedLabel}}</text>
    </view>
    <view class="glass-card stat-card">
      <text class="stat-value">{{stats.totalXp}}</text>
      <text class="stat-label">{{totalXpLabel}}</text>
    </view>
  </view>

  <view class="glass-card card-padding profile-favorite">
    <text class="muted-text">{{favoriteBuddyLabel}}</text>
    <text class="favorite-name">{{favoriteBuddyValue}}</text>
  </view>

  <view class="glass-card card-padding" style="margin-top: 24rpx;">
    <view class="section-title" style="font-size: 28rpx; margin-bottom: 18rpx;">{{registeredDevicesLabel}}</view>
    <view class="device-list">
      <view wx:for="{{devices}}" wx:key="id" class="device-row">
        <view class="device-main">
          <text class="device-emoji">{{item.emoji}}</text>
          <view>
            <text class="device-name">{{item.name}}</text>
            <text class="muted-text device-mood">{{item.mood}}</text>
          </view>
        </view>
        <text class="muted-text">{{item.status}}</text>
      </view>
    </view>
  </view>

  <view class="glass-card card-padding" style="margin-top: 22rpx;">
    <text class="section-title" style="font-size: 28rpx; margin-bottom: 18rpx;">{{preferencesLabel}}</text>
    <view class="setting-row">
      <text>{{languageLabel}}</text>
      <text class="muted-text">{{selectedLanguageName}}</text>
    </view>
    <view class="language-options">
      <view wx:for="{{languages}}" wx:key="code" class="lang-pill {{currentLanguage === item.code ? 'active' : ''}}" data-code="{{item.code}}" bindtap="setLanguage">
        <text>{{item.name}}</text>
      </view>
    </view>
    <view class="setting-row">
      <text>{{parentalLockLabel}}</text>
      <text class="muted-text">{{enabledLabel}}</text>
    </view>
    <view class="setting-row">
      <text>{{deviceSafetyLabel}}</text>
      <text class="muted-text">{{onLabel}}</text>
    </view>
    <view class="setting-row">
      <text>{{supportLabel}}</text>
      <text class="muted-text">{{chatLabel}}</text>
    </view>
  </view>

  <custom-tab-bar />
</view>
