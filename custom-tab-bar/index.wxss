.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 78px;
  padding: 10rpx 14rpx env(safe-area-inset-bottom);
  gap: 12rpx;
  background: rgba(10, 14, 27, 0.96);
  border-top: none;
  box-shadow: 0 -10rpx 28rpx rgba(0, 0, 0, 0.24);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  color: #8a94a6;
  padding: 10rpx 0;
  border-radius: 24rpx;
  transition: color 180ms ease, transform 180ms ease, background 180ms ease;
}

.tab-item.active {
  color: #fff;
  background: linear-gradient(135deg, rgba(255, 207, 74, 0.2), rgba(255, 107, 157, 0.16));
  transform: translateY(-3px);
}

.tab-item.active .tab-pill {
  opacity: 1;
}

.icon-wrap {
  width: 26px;
  height: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-svg {
  width: 24px;
  height: 24px;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  fill: none;
}

.tab-text {
  font-size: 12px;
  line-height: 1;
  font-weight: 600;
}

.tab-pill {
  position: absolute;
  bottom: 6rpx;
  width: 36rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #4ecdc4;
  opacity: 0;
  transition: opacity 180ms ease;
}
