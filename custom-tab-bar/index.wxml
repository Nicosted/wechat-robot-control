<view class="tab-bar" style="background: {{backgroundColor}}">
  <view
    wx:for="{{tabList}}"
    wx:key="text"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    data-page-path="{{item.pagePath}}"
    bindtap="switchTab"
  >
    <view class="icon-wrap">
      <block wx:if="{{item.icon === 'home'}}">
        <svg viewBox="0 0 24 24" class="icon-svg" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <path d="M9 22V12h6v10" />
        </svg>
      </block>
      <block wx:elif="{{item.icon === 'partners'}}">
        <svg viewBox="0 0 24 24" class="icon-svg" xmlns="http://www.w3.org/2000/svg">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
          <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
          <path d="M23 7.75a4 4 0 1 1-3-3.87" />
        </svg>
      </block>
      <block wx:elif="{{item.icon === 'tasks'}}">
        <svg viewBox="0 0 24 24" class="icon-svg" xmlns="http://www.w3.org/2000/svg">
          <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
          <path d="M9 11l3 3L22 4" />
          <path d="M12 17l-2 2-3-3" />
        </svg>
      </block>
      <block wx:elif="{{item.icon === 'academy'}}">
        <svg viewBox="0 0 24 24" class="icon-svg" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
          <path d="M12 6v8" />
          <path d="M10 10h4" />
        </svg>
      </block>
      <block wx:else>
        <svg viewBox="0 0 24 24" class="icon-svg" xmlns="http://www.w3.org/2000/svg">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
          <path d="M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8" />
        </svg>
      </block>
    </view>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
